# Environment configuration template
# Copy to .env and fill in your values. Never commit .env.

# ── Application ──────────────────────────────────────────
APP_ENV=local                         # local | test | production
LOG_LEVEL=INFO
SECRET_KEY=changeme

# ── Orchestrator ─────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000

# ── Model Gateway ────────────────────────────────────────
MODEL_GATEWAY_HOST=0.0.0.0
MODEL_GATEWAY_PORT=8001
MODEL_GATEWAY_URL=http://model-gateway:8001

# ── Sandbox Worker ───────────────────────────────────────
SANDBOX_WORKER_URL=http://sandbox-worker:8002
SANDBOX_NETWORK_ACCESS=false
SANDBOX_MAX_CPU_SECONDS=60
SANDBOX_MAX_MEMORY_MB=512

# ── Database ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=swe_agents
POSTGRES_USER=swe
POSTGRES_PASSWORD=changeme
DATABASE_URL=******postgres:5432/swe_agents

# ── Cloud LLM providers (leave blank to disable) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── LangSmith (optional tracing) ─────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tiered-swe-agents

# ── Observability ─────────────────────────────────────────
OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PUSHGATEWAY=http://pushgateway:9091
