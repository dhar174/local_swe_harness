FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy workspace definition and source
COPY pyproject.toml uv.lock ./
COPY apps/orchestrator/pyproject.toml apps/orchestrator/
COPY packages/ packages/
COPY apps/orchestrator/src/ apps/orchestrator/src/
COPY config/ config/
# Install workspace
RUN uv sync --no-dev
CMD ["uv", "run", "uvicorn", "swe_agents.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
