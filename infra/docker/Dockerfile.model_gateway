FROM python:3.14-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
COPY services/model_gateway/pyproject.toml services/model_gateway/
COPY packages/ packages/
COPY services/model_gateway/src/ services/model_gateway/src/
COPY config/ config/

RUN uv sync --no-dev
CMD ["uv", "run", "uvicorn", "model_gateway.app:app", "--host", "0.0.0.0", "--port", "8001"]
