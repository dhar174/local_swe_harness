# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force binary treatment for common binary types
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.lock text eol=lf
# Explicitly mark Python source files as text
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf

# YAML/TOML/JSON
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Dockerfile
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Linguist overrides
*.py linguist-language=Python
